# Example environment variables
# Copy this to .env and update with your values

# PostgreSQL Database URL
# Local: postgresql://postgres:postgres@localhost:5432/bountyboard
# Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# Neon: postgresql://[user]:[password]@[endpoint].neon.tech/[dbname]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bountyboard

# Replit Auth (for development, can use dummy values)
REPLIT_CLIENT_ID=dummy
REPLIT_CLIENT_SECRET=dummy

# Optional: Video storage provider (defaults to mock)
VIDEO_STORAGE_PROVIDER=mock

# AIR.INC INTEGRATION (DISABLED)
# Uncomment and configure if you want to enable Air.inc sync
# AIR_INC_API_KEY=your_api_key_here
# AIR_INC_API_URL=https://api.air.inc/v1
# AIR_INC_ENABLED=true