{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    },
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/admin/briefs",
      "destination": "/api/admin-briefs-simple"
    },
    {
      "source": "/api/admin/submissions",
      "destination": "/api/admin-submissions-real"
    },
    {
      "source": "/api/admin/brief-assignments",
      "destination": "/api/admin/brief-assignments"
    },
    {
      "source": "/api/influencers/register",
      "destination": "/api/influencers/register"
    },
    {
      "source": "/api/briefs/by-slug/:slug",
      "destination": "/api/briefs-by-slug?slug=:slug"
    },
    {
      "source": "/api/briefs/id/:id",
      "destination": "/api/briefs-by-id?id=:id"
    },
    {
      "source": "/api/briefs/:id/submissions",
      "destination": "/api/briefs/[id]/submissions"
    },
    {
      "source": "/api/briefs/:id",
      "destination": "/api/briefs-handler?id=:id"
    },
    {
      "source": "/api/submissions",
      "destination": "/api/submissions"
    },
    {
      "source": "/api/submissions/:id/feedback",
      "destination": "/api/submissions-feedback?id=:id"
    },
    {
      "source": "/api/submissions/:id/status",
      "destination": "/api/submissions-status-simple?id=:id"
    },
    {
      "source": "/api/submissions/:id/payout",
      "destination": "/api/submissions/[id]/payout"
    },
    {
      "source": "/api/submissions/:id/finance-approval",
      "destination": "/api/submissions/[id]/finance-approval"
    },
    {
      "source": "/api/submissions/:id/mark-paid",
      "destination": "/api/submissions/[id]/mark-paid"
    },
    {
      "source": "/api/feedback/:id",
      "destination": "/api/feedback-delete?id=:id"
    },
    {
      "source": "/api/templates/:id",
      "destination": "/api/templates/[id]"
    },
    {
      "source": "/api/influencers/:id/status",
      "destination": "/api/influencers/[id]/status"
    },
    {
      "source": "/api/influencers/portal",
      "destination": "/api/influencers/portal"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}